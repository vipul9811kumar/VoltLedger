{
  "name": "voltledger",
  "version": "0.1.0",
  "private": true,
  "description": "Financial-grade battery residual risk intelligence for lenders, auctions, and secondary markets",
  "workspaces": [
    "apps/api",
    "apps/ingestion",
    "apps/dashboard",
    "packages/types",
    "packages/db",
    "tools/synthetic-generator"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "dotenv -e .env --override -- prisma generate --schema packages/db/prisma/schema.prisma",
    "db:migrate": "dotenv -e .env --override -- prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "db:migrate:deploy": "dotenv -e .env --override -- prisma migrate deploy --schema packages/db/prisma/schema.prisma",
    "db:migrate:reset": "dotenv -e .env --override -- prisma migrate reset --schema packages/db/prisma/schema.prisma",
    "db:seed": "dotenv -e .env --override -- tsx packages/db/src/seed.ts",
    "db:studio": "dotenv -e .env --override -- prisma studio --schema packages/db/prisma/schema.prisma",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "ingestion:dev": "dotenv -e .env --override -- tsx apps/ingestion/src/index.ts",
    "ingestion:load": "dotenv -e .env --override -- tsx apps/ingestion/src/loaders/ndjson.loader.ts",
    "generate:synthetic": "dotenv -e .env --override -- tsx tools/synthetic-generator/src/index.ts",
    "generate:synthetic:small": "dotenv -e .env --override -- tsx tools/synthetic-generator/src/index.ts --batteries 10 --weeks 52",
    "generate:synthetic:fleet": "dotenv -e .env --override -- tsx tools/synthetic-generator/src/index.ts --batteries 100 --weeks 260",
    "generate:synthetic:seed": "dotenv -e .env --override -- tsx tools/synthetic-generator/src/index.ts --batteries 50 --weeks 260 --seed-db"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "prettier": "^3.2.0",
    "prisma": "^5.14.0",
    "tsx": "^4.11.0",
    "dotenv-cli": "^7.4.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
