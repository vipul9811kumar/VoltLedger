{
  "name": "@voltledger/db",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "migrate": "pnpm exec prisma migrate dev",
    "migrate:deploy": "pnpm exec prisma migrate deploy",
    "migrate:reset": "pnpm exec prisma migrate reset",
    "generate": "pnpm exec prisma generate",
    "seed": "pnpm exec tsx src/seed.ts",
    "studio": "pnpm exec prisma studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0"
  },
  "devDependencies": {
    "prisma": "^5.14.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
